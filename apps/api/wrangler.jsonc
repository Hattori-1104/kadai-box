{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "kadai-box",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-28",
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist",
	},
